# ─── Database ────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase pooler or direct)
DATABASE_URL="postgresql://user:password@host:5432/database"

# ─── Auth ────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens (min 32 characters)
JWT_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"

# ─── App ─────────────────────────────────────────────────────────────
# Base URL of the deployed application
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# ─── Node (optional) ────────────────────────────────────────────────
# Set to "production" in production
NODE_ENV="production"
