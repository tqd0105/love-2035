// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum Role {
  ADMIN
  COUPLE
  APPROVED_GUEST
  PUBLIC_VISITOR
}

enum Mode {
  RELATIONSHIP
  WEDDING
  ARCHIVE
}

enum Visibility {
  PUBLIC
  APPROVED_GUEST
  COUPLE
  PASSWORD_LOCKED
}

enum EventType {
  ANNIVERSARY
  MILESTONE
  WEDDING
  CUSTOM
}

enum TimelineType {
  MEMORY
  MILESTONE
  ANNIVERSARY
  WEDDING
}

enum LetterType {
  REGULAR
  TIME_LOCKED
  PASSWORD_LOCKED
  FUTURE_MESSAGE
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum ProfileOwner {
  PERSON_A
  PERSON_B
}

enum ProfileSectionType {
  LIKES
  DISLIKES
  UNKNOWN_FACTS
  LESSONS_LEARNED
  FAVORITE_MEMORY
  QUOTE
}

enum VaultContentType {
  SECRET_LETTER
  PRIVATE_MEMORY
  TIME_CAPSULE
  PRIVATE_MEDIA
}

//
// CORE MODE CONFIG
//

model SystemConfig {
  id              String   @id @default(uuid())
  mode            Mode
  weddingEnabled  Boolean  @default(false)
  archiveEnabled  Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@map("system_config")
}

//
// AUTH
//

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          Role
  createdAt     DateTime       @default(now())

  refreshTokens RefreshToken[]
  letterReads   LetterRead[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model GuestRequest {
  id           String   @id @default(uuid())
  name         String
  email        String
  relationship String
  message      String?
  passwordHash String?
  status       String
  createdAt    DateTime @default(now())
  approvedAt   DateTime?
  approvedBy   String?

  @@map("guest_requests")
}

model InviteToken {
  id        String    @id @default(uuid())
  token     String    @unique
  label     String?
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdBy String
  createdAt DateTime  @default(now())

  @@map("invite_tokens")
}

//
// EVENT SYSTEM
//

model Event {
  id           String     @id @default(uuid())
  title        String
  description  String?
  eventType    EventType
  date         DateTime
  isRecurring  Boolean    @default(false)
  recurrence   String?
  visibility   Visibility
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  timelineEvents TimelineEvent[]

  @@map("events")
}

//
// MEDIA SYSTEM
//

model Media {
  id          String     @id @default(uuid())
  url         String
  mediaType   MediaType
  visibility  Visibility
  blurDataUrl String?
  width       Int?
  height      Int?
  uploadedBy  String
  createdAt   DateTime   @default(now())

  @@map("media")
}

//
// TIMELINE
//

model TimelineEvent {
  id            String        @id @default(uuid())
  title         String
  description   String?
  timelineType  TimelineType
  date          DateTime
  visibility    Visibility
  isHighlighted Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  eventId String?
  event   Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@map("timeline_events")
}

//
// LETTER SYSTEM
//

model Letter {
  id              String      @id @default(uuid())
  title           String
  content         String
  letterType      LetterType
  visibility      Visibility
  unlockAt        DateTime?
  passwordHash    String?
  moodTags        String[]
  musicUrl        String?
  isReadTracking  Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  reads LetterRead[]

  @@map("letters")
}

model LetterRead {
  id       String   @id @default(uuid())
  letterId String
  userId   String
  readAt   DateTime @default(now())

  letter Letter @relation(fields: [letterId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([letterId, userId])
  @@map("letter_reads")
}

//
// PROFILE
//

model Profile {
  id         String        @id @default(uuid())
  owner      ProfileOwner
  displayName String
  bio        String?
  avatarId   String?
  visibility Visibility
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  sections ProfileSection[]

  @@map("profiles")
}

model ProfileSection {
  id         String             @id @default(uuid())
  profileId  String
  sectionType ProfileSectionType
  content    String
  orderIndex Int
  visibility Visibility

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_sections")
}

//
// PRIVACY VAULT
//

model VaultItem {
  id               String           @id @default(uuid())
  title            String
  contentEncrypted String
  vaultType        VaultContentType
  unlockAt         DateTime?
  requiresPassword Boolean          @default(false)
  passwordHash     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("vault_items")
}

//
// WEDDING SYSTEM
//

model WeddingWish {
  id        String   @id @default(uuid())
  name      String
  message   String
  photoUrl  String?
  createdAt DateTime @default(now())

  @@map("wedding_wishes")
}